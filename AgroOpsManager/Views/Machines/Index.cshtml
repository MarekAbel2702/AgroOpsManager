@model IEnumerable<AgroOpsManager.Core.Entities.Machine>
@using AgroOpsManager.Core.Enums

@{
    ViewData["Title"] = "Maszyny";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
        <h1 class="page-title">Maszyny</h1>
        <p class="page-subtitle">
            Ewidencja maszyn, statusów, motogodzin oraz przeglądów serwisowych.
        </p>
    </div>

    <div class="page-actions">
        <a class="btn btn-outline-warning" asp-controller="Machines" asp-action="ServiceAlerts">
            Alerty serwisowe
        </a>

        <a class="btn btn-primary" asp-controller="Machines" asp-action="Create">
            Dodaj maszynę
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] is not null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="filter-card">
    <form method="get" asp-controller="Machines" asp-action="Index" class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Szukaj</label>
            <input type="text"
                   name="searchTerm"
                   value="@ViewBag.SearchTerm"
                   class="form-control"
                   placeholder="Nazwa lub numer seryjny" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Typ</label>
            <select name="type" class="form-select">
                <option value="">Wszystkie</option>
                @foreach (var type in Enum.GetValues<MachineType>())
                {
                    if (ViewBag.Type == type.ToString())
                    {
                        <option value="@type" selected>@type</option>
                    }
                    else
                    {
                        <option value="@type">@type</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Status</label>
            <select name="status" class="form-select">
                <option value="">Wszystkie</option>
                @foreach (var status in Enum.GetValues<MachineStatus>())
                {
                    if (ViewBag.Status == status.ToString())
                    {
                        <option value="@status" selected>@status</option>
                    }
                    else
                    {
                        <option value="@status">@status</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-outline-primary w-100">
                Filtruj
            </button>
        </div>
    </form>
</div>

<div class="content-card">
    <div class="content-card-header">
        <span>Lista maszyn</span>
        <span class="text-muted small">@Model.Count() rekordów</span>
    </div>

    <div class="content-card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info mb-0">
                Brak maszyn spełniających wybrane kryteria.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nazwa</th>
                            <th>Typ</th>
                            <th>Numer seryjny</th>
                            <th>Motogodziny</th>
                            <th>Serwis</th>
                            <th>Status</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var machine in Model)
                        {
                            var hoursSinceService = machine.CurrentWorkingHours - machine.WorkingHoursAtLastService;
                            var exceededBy = hoursSinceService - machine.ServiceIntervalHours;

                            <tr>
                                <td>
                                    <div class="entity-title">@machine.Name</div>
                                    <div class="small text-muted">rok produkcji: @machine.ProductionYear</div>
                                </td>
                                <td>@machine.Type</td>
                                <td>@machine.SerialNumber</td>
                                <td>@machine.CurrentWorkingHours h</td>
                                <td>
                                    @if (machine.RequiresService())
                                    {
                                        <span class="badge bg-danger">
                                            Wymaga serwisu
                                        </span>

                                        <div class="small text-muted mt-1">
                                            przekroczono o @exceededBy h
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            OK
                                        </span>

                                        <div class="small text-muted mt-1">
                                            @hoursSinceService / @machine.ServiceIntervalHours h
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (machine.Status == MachineStatus.Available)
                                    {
                                        <span class="badge bg-success">@machine.Status</span>
                                    }
                                    else if (machine.Status == MachineStatus.InUse)
                                    {
                                        <span class="badge bg-primary">@machine.Status</span>
                                    }
                                    else if (machine.Status == MachineStatus.InService)
                                    {
                                        <span class="badge bg-warning text-dark">@machine.Status</span>
                                    }
                                    else if (machine.Status == MachineStatus.Broken)
                                    {
                                        <span class="badge bg-danger">@machine.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@machine.Status</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a class="btn btn-sm btn-outline-secondary"
                                           asp-controller="Machines"
                                           asp-action="Details"
                                           asp-route-id="@machine.Id">
                                            Szczegóły
                                        </a>

                                        <a class="btn btn-sm btn-outline-primary"
                                           asp-controller="Machines"
                                           asp-action="Edit"
                                           asp-route-id="@machine.Id">
                                            Edytuj
                                        </a>

                                        <a class="btn btn-sm btn-outline-danger"
                                           asp-controller="Machines"
                                           asp-action="Delete"
                                           asp-route-id="@machine.Id">
                                            Usuń
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>