@model IEnumerable<AgroOpsManager.Core.Entities.Field>
@using AgroOpsManager.Core.Enums

@{
    ViewData["Title"] = "Pola uprawne";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
        <h1 class="page-title">Pola uprawne</h1>
        <p class="page-subtitle">
            Zarządzanie polami, lokalizacjami, powierzchnią oraz aktualnymi uprawami.
        </p>
    </div>

    <div class="page-actions">
        <a class="btn btn-primary" asp-controller="Fields" asp-action="Create">
            Dodaj pole
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] is not null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="filter-card">
    <form method="get" asp-controller="Fields" asp-action="Index" class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Szukaj</label>
            <input type="text"
                   name="searchTerm"
                   value="@ViewBag.SearchTerm"
                   class="form-control"
                   placeholder="Nazwa pola lub lokalizacja" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Status</label>
            <select name="status" class="form-select">
                <option value="">Wszystkie</option>
                @foreach (var status in Enum.GetValues<FieldStatus>())
                {
                    if (ViewBag.Status == status.ToString())
                    {
                        <option value="@status" selected>@status</option>
                    }
                    else
                    {
                        <option value="@status">@status</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-outline-primary w-100">
                Filtruj
            </button>
        </div>
    </form>
</div>

<div class="content-card">
    <div class="content-card-header">
        <span>Lista pól</span>
        <span class="text-muted small">@Model.Count() rekordów</span>
    </div>

    <div class="content-card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info mb-0">
                Brak pól spełniających wybrane kryteria.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nazwa</th>
                            <th>Lokalizacja</th>
                            <th>Powierzchnia</th>
                            <th>Gleba</th>
                            <th>Uprawa</th>
                            <th>Status</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var field in Model)
                        {
                            <tr>
                                <td>
                                    <div class="entity-title">@field.Name</div>
                                    @if (!string.IsNullOrWhiteSpace(field.Notes))
                                    {
                                        <div class="small text-muted">ma notatki</div>
                                    }
                                </td>
                                <td>@field.Location</td>
                                <td>@field.AreaInHectares.ToString("0.00") ha</td>
                                <td>@field.SoilType</td>
                                <td>@field.CurrentCrop</td>
                                <td>
                                    @if (field.Status == FieldStatus.Active)
                                    {
                                        <span class="badge bg-success">@field.Status</span>
                                    }
                                    else if (field.Status == FieldStatus.Fallow)
                                    {
                                        <span class="badge bg-warning text-dark">@field.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@field.Status</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a class="btn btn-sm btn-outline-secondary"
                                           asp-controller="Fields"
                                           asp-action="Details"
                                           asp-route-id="@field.Id">
                                            Szczegóły
                                        </a>

                                        <a class="btn btn-sm btn-outline-primary"
                                           asp-controller="Fields"
                                           asp-action="Edit"
                                           asp-route-id="@field.Id">
                                            Edytuj
                                        </a>

                                        <a class="btn btn-sm btn-outline-danger"
                                           asp-controller="Fields"
                                           asp-action="Delete"
                                           asp-route-id="@field.Id">
                                            Usuń
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="2">Łączna powierzchnia widocznych pól</th>
                            <th>@Model.Sum(x => x.AreaInHectares).ToString("0.00") ha</th>
                            <th colspan="4"></th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>