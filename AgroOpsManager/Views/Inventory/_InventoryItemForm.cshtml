@model AgroOpsManager.Web.ViewModels.Inventory.InventoryItemFormViewModel
@using AgroOpsManager.Core.Enums

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<input type="hidden" asp-for="Id" />

<div class="form-section">
    <div class="form-section-title">Dane pozycji magazynowej</div>
    <p class="form-section-description">
        Podaj nazwę, kategorię, jednostkę i dostawcę zasobu.
    </p>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="np. Saletra amonowa" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Category" class="form-label"></label>
            <select asp-for="Category" asp-items="Html.GetEnumSelectList<InventoryCategory>()" class="form-select"></select>
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="SupplierName" class="form-label"></label>
            <input asp-for="SupplierName" class="form-control" placeholder="np. AgroChem Polska" />
            <span asp-validation-for="SupplierName" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="ExpirationDate" class="form-label"></label>
            <input asp-for="ExpirationDate" class="form-control" type="date" />
            <span asp-validation-for="ExpirationDate" class="text-danger"></span>
        </div>
    </div>
</div>

<div class="form-section">
    <div class="form-section-title">Stan i wycena</div>
    <p class="form-section-description">
        Ilość, minimum oraz cena jednostkowa służą do alertów i wyliczania wartości magazynu.
    </p>

    <div class="row">
        <div class="col-md-3 mb-3">
            <label asp-for="Quantity" class="form-label"></label>
            <input asp-for="Quantity" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="MinimumQuantity" class="form-label"></label>
            <input asp-for="MinimumQuantity" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="MinimumQuantity" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="Unit" class="form-label"></label>
            <input asp-for="Unit" class="form-control" placeholder="kg, L, szt." />
            <span asp-validation-for="Unit" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="UnitPrice" class="form-label"></label>
            <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="UnitPrice" class="text-danger"></span>
        </div>
    </div>

    <div class="alert alert-info mb-0">
        <strong>Reguła magazynowa:</strong>
        pozycja będzie oznaczona jako niski stan, gdy aktualna ilość będzie mniejsza lub równa minimalnemu stanowi.
    </div>
</div>

<div class="form-section">
    <div class="form-section-title">Notatki</div>
    <p class="form-section-description">
        Dodaj informacje o partii, sposobie przechowywania lub dodatkowych uwagach.
    </p>

    <textarea asp-for="Notes" class="form-control" rows="4" placeholder="Dodatkowe informacje o zasobie..."></textarea>
    <span asp-validation-for="Notes" class="text-danger"></span>
</div>