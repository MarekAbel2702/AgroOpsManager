@model AgroOpsManager.Web.ViewModels.Inventory.InventoryItemFormViewModel

@{
    ViewData["Title"] = "Dodaj pozycję magazynową";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
        <h1 class="page-title">Dodaj pozycję magazynową</h1>
        <p class="page-subtitle">Dodaj nawóz, paliwo, nasiona, części lub inny zasób.</p>
    </div>

    <div class="page-actions">
        <a class="btn btn-outline-secondary" asp-controller="Inventory" asp-action="Index">
            Wróć do listy
        </a>
    </div>
</div>

<div class="form-page-card">
    <div class="form-page-header">
        <h2 class="form-page-title fs-5">Nowa pozycja magazynowa</h2>
        <p class="form-page-subtitle">Uzupełnij stan, minimum i cenę jednostkową.</p>
    </div>

    <div class="form-page-body">
        <form asp-controller="Inventory" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <partial name="_InventoryItemForm" model="Model" />

            <div class="form-actions">
                <a class="btn btn-outline-secondary" asp-controller="Inventory" asp-action="Index">
                    Anuluj
                </a>

                <button type="submit" class="btn btn-primary">
                    Zapisz pozycję
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}